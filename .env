# cafe_system/.env

# Application
APP_NAME=Cafe System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/cafe_system

# Database
DB_HOST=localhost
DB_NAME=cafe_system
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_PERSISTENT=false

# Session
SESSION_TIMEOUT=1800
SESSION_LIFETIME=7200
COOKIE_DOMAIN=

# Security
RATE_LIMIT=60
LOGIN_RATE_LIMIT=5
LOGIN_LOCKOUT_WINDOW=15
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Uploads (future)
MAX_UPLOAD_SIZE=5242880